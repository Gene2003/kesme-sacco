# Copy this file to .env for local dev. On Render, set these in the dashboard.
SECRET_KEY=your-very-secret-django-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Production database — leave blank for local SQLite.
# On Render, paste the Internal Database URL from the Postgres instance.
DATABASE_URL=

# CORS — origins allowed to call the API (comma-separated, no trailing slash)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# CSRF — required for Django admin login over HTTPS in production
CSRF_TRUSTED_ORIGINS=
